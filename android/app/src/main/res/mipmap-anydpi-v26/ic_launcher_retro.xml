<?xml version="1.0" encoding="utf-8"?>
<!-- "retro" alternate launcher icon. The foreground α is sized to ~78% and
     biased right so its tail just reaches the frame edge (matching the desktop
     art the author wants) while the bowl and crossbar stay inside the adaptive
     safe zone — the launcher mask only ever grazes the tail, never a large part.
     Earlier the art was full-bleed and the mask ate the whole outer ring. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
  <background android:drawable="@color/ic_launcher_background"/>
  <foreground android:drawable="@mipmap/ic_launcher_retro_fg"/>
</adaptive-icon>
