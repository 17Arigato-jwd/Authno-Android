<?xml version="1.0" encoding="utf-8"?>
<!-- "retro" alternate launcher icon: the glyph is composed to bleed into the
     corner and be cropped by the mask (author's intended framing), so the
     foreground is full-bleed — no inset — over the solid-white background. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
  <background android:drawable="@color/ic_launcher_background"/>
  <foreground android:drawable="@mipmap/ic_launcher_retro_fg"/>
</adaptive-icon>
