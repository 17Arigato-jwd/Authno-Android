<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_flame_gradient.xml
  Minimalist flame icon: light orange (#FFD97D) → deep orange (#FF5C00),
  gradient flows top-left to bottom-right.
  Matches the FlameIcon in GradientIcons.jsx.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Outer flame body -->
    <path
        android:pathData="M12,2.25c-0.38,0 -0.7,0.21 -0.88,0.54C9.27,6.27 6,10.5 6,14.5a6,6 0,0 0,12 0c0,-4 -3.27,-8.23 -5.12,-11.71A1,1 0,0 0,12 2.25Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="24"  android:endY="24">
                <item android:offset="0.0" android:color="#FFD97D" />
                <item android:offset="1.0" android:color="#FF5C00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner highlight -->
    <path
        android:pathData="M12,7.5c-0.25,0 -0.47,0.14 -0.59,0.36C10.52,9.7 9.5,12 9.5,14a2.5,2.5 0,0 0,5 0c0,-2 -0.99,-4.22 -1.9,-6.13A0.67,0.67 0,0 0,12 7.5Z"
        android:fillColor="#47FFFFFF" />

</vector>
