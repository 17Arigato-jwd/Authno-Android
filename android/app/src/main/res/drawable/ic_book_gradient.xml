<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_book_gradient.xml
  Minimalist open-book icon: lime (#C8F59E) → green (#16A34A),
  gradient flows top-left to bottom-right.
  Matches the BookIcon in GradientIcons.jsx.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Left page -->
    <path
        android:pathData="M2,6a2,2 0,0 1,2 -2h6.5v14H4a2,2 0,0 1,-2 -2V6Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="24"  android:endY="24">
                <item android:offset="0.0" android:color="#C8F59E" />
                <item android:offset="1.0" android:color="#16A34A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right page -->
    <path
        android:pathData="M13.5,4H19a2,2 0,0 1,2 2v10a2,2 0,0 1,-2 2h-5.5V4Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="24"  android:endY="24">
                <item android:offset="0.0" android:color="#C8F59E" />
                <item android:offset="1.0" android:color="#16A34A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Spine shadow -->
    <path
        android:pathData="M10.5,4h3v14h-3Z"
        android:fillColor="#2E000000" />

    <!-- Page lines — left -->
    <path android:pathData="M4.5,8 L9,8"   android:strokeColor="#8DFFFFFF" android:strokeWidth="1.2" android:strokeLineCap="round" android:fillColor="#00000000" />
    <path android:pathData="M4.5,11 L9,11" android:strokeColor="#8DFFFFFF" android:strokeWidth="1.2" android:strokeLineCap="round" android:fillColor="#00000000" />
    <path android:pathData="M4.5,14 L9,14" android:strokeColor="#8DFFFFFF" android:strokeWidth="1.2" android:strokeLineCap="round" android:fillColor="#00000000" />

    <!-- Page lines — right -->
    <path android:pathData="M15,8 L19.5,8"   android:strokeColor="#8DFFFFFF" android:strokeWidth="1.2" android:strokeLineCap="round" android:fillColor="#00000000" />
    <path android:pathData="M15,11 L19.5,11" android:strokeColor="#8DFFFFFF" android:strokeWidth="1.2" android:strokeLineCap="round" android:fillColor="#00000000" />
    <path android:pathData="M15,14 L19.5,14" android:strokeColor="#8DFFFFFF" android:strokeWidth="1.2" android:strokeLineCap="round" android:fillColor="#00000000" />

</vector>
