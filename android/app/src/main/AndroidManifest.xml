<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- ── Main activity ── -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Open .authbook files tapped in file managers / email / browser -->
            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\.authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\.authbook" />
            </intent-filter>

            <!-- Open .extbk extension bundles tapped in file managers / browser -->
            <intent-filter android:label="Install AuthNo Extension">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-extbk" />
            </intent-filter>

            <intent-filter android:label="Install AuthNo Extension">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\.extbk" />
            </intent-filter>

            <intent-filter android:label="Install AuthNo Extension">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\.extbk" />
            </intent-filter>

            <!--
                ── OAuth redirect URI handlers (v1.2.0) ──────────────────────
                Required for all cloud providers using the PKCE flow.
                @capacitor/browser opens the provider's auth page, then redirects
                back to this custom scheme. MainActivity.handleOAuthRedirect()
                catches the intent and forwards the URL to JS via a CustomEvent.

                Each provider has its own path segment so they don't interfere.
            -->

            <!-- Google Drive -->
            <intent-filter android:label="AuthNo OAuth — Google Drive">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.aurorastudios.authno"
                      android:host="oauth2"
                      android:pathPrefix="/gdrive" />
            </intent-filter>

            <!-- Dropbox -->
            <intent-filter android:label="AuthNo OAuth — Dropbox">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.aurorastudios.authno"
                      android:host="oauth2"
                      android:pathPrefix="/dropbox" />
            </intent-filter>

            <!-- OneDrive / Microsoft -->
            <intent-filter android:label="AuthNo OAuth — OneDrive">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.aurorastudios.authno"
                      android:host="oauth2"
                      android:pathPrefix="/onedrive" />
            </intent-filter>

        </activity>

        <!-- ── Streak Widget: provider ── -->
        <receiver
            android:name=".StreakWidgetProvider"
            android:label="@string/widget_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/streak_widget_info" />
        </receiver>

        <!-- ── Streak Widget: configuration activity ── -->
        <activity
            android:name=".StreakWidgetConfigActivity"
            android:label="@string/widget_config_label"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- ── File provider ── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
            OAuthFinishActivity: closes the Custom Tab browser after OAuth redirect.
            noHistory=true keeps it off the back stack.
            Theme.NoDisplay makes it invisible (no flash).
        -->
        <activity
            android:name=".OAuthFinishActivity"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoDisplay"
            android:exported="false" />

    </application>

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
                     android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
                     android:minSdkVersion="30" />

    <!--
        ── Package visibility (Android 11 / API 30+) ──────────────────────────
        Without this <queries> block, PackageManager.resolveActivity() and
        CustomTabsClient.getPackageName() return null on Android 11+ even if
        a browser is installed. This is the #1 cause of the silent "Opening
        browser..." hang — the intent fires but finds no target.

        We declare two intents:
          1. CustomTabsService — lets CustomTabsClient.getPackageName() find
             browsers that support Custom Tabs (Chrome, Firefox, Brave, etc.)
          2. ACTION_VIEW + https — fallback so startActivity(ACTION_VIEW) works
             when no Custom Tabs browser is available.
    -->
    <queries>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
    </queries>

</manifest>
