<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\.authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\.authbook" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- ── Permissions ──────────────────────────────────────────────────────

         INTERNET
         Active now: Capacitor WebView bridge.
         Future: cloud sync, AI writing assistant, auto-backup.

         POST_NOTIFICATIONS  (Android 13+)
         Active now: requested during first-launch onboarding.
         Future: daily writing reminders, streak alerts, backup notifications.

         READ_MEDIA_IMAGES  (Android 13+)
         Active now: user avatar photo picker in Settings already works
         via <input type="file"> — this permission unlocks the gallery picker
         for book cover art when that feature ships.
         Future: book covers, inline story images, storyboard attachments.

         READ_EXTERNAL_STORAGE  (Android ≤ 12, maxSdkVersion 32)
         Same purpose as READ_MEDIA_IMAGES on older devices.
         Silently ignored on Android 13+.

         CAMERA
         Active now: declared for avatar capture (Settings).
         Future: book cover from camera, writing prompt image capture.

         VIBRATE
         Future: haptic feedback on streak milestones and goal completion.

         NOTE — No WRITE_EXTERNAL_STORAGE or MANAGE_EXTERNAL_STORAGE.
         File saving uses either:
           • Directory.External / Directory.Data (app-specific, zero permission)
           • ACTION_CREATE_DOCUMENT SAF (grants its own URI permission)
         This keeps the Play Store data-safety declaration clean.
    ──────────────────────────────────────────────────────────────────────── -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
                     android:maxSdkVersion="32" />
    <!--
         MANAGE_EXTERNAL_STORAGE — Android 11+ (API 30+)
         Allows the On Device scanner to find .authbook files anywhere on the
         device, mirroring how Adobe Acrobat auto-locates PDFs.
         The user explicitly grants this via the "Grant Storage Access" button
         in the HomeScreen On Device tab — it is NEVER requested silently.
         Note: Google Play requires a declaration in the data-safety form for
         this permission. Declare that it is used to locate user-created files.
    -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
                     tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />

</manifest>
