<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Open .authbook files from any file manager (content URI) -->
            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\.authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\.authbook" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- ── Permissions ──────────────────────────────────────────────────────

         INTERNET
         Required now: Capacitor WebView, future cloud sync / AI features.

         POST_NOTIFICATIONS  (Android 13+, API 33+)
         Required now: none. Future: writing streak reminders, daily goal
         alerts, backup completion toasts. Declared here so we can request
         it when the feature ships without an app update.

         READ_MEDIA_IMAGES  (Android 13+, API 33+)
         Required now: none. Future: book cover art, inline images,
         storyboard image attachments. Scoped replacement for READ_EXTERNAL_STORAGE
         on modern Android.

         READ_EXTERNAL_STORAGE  (Android ≤ 12, capped at API 32)
         Fallback for READ_MEDIA_IMAGES on older devices. Only needed if the
         user picks an image from their gallery on Android 9–12. Harmless on
         Android 13+ because it is silently ignored.

         CAMERA
         Required now: none. Future: cover photo from camera, writing
         prompt image capture.

         NOTE — We do NOT declare WRITE_EXTERNAL_STORAGE or
         MANAGE_EXTERNAL_STORAGE. All file saving uses either:
           • Directory.External (app-specific dir, never needs permission)
           • Storage Access Framework via ACTION_CREATE_DOCUMENT (SAF grants
             its own URI permission — no manifest entry needed)
         This keeps the Play Store data-safety declaration clean.
    ──────────────────────────────────────────────────────────────────────── -->

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <uses-permission android:name="android.permission.CAMERA" />

    <uses-permission android:name="android.permission.VIBRATE" />

</manifest>
