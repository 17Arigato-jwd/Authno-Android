<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- ── Main activity ── -->
        <activity
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode">

            <!-- The MAIN/LAUNCHER filter lives on the activity-aliases below so
                 the launcher icon can be switched at runtime (AppIconPlugin
                 toggles which alias is enabled). File-association VIEW filters
                 must stay here: aliases are launcher entry points only. -->

            <!-- Share target: text shared from other apps opens the
                 book/chapter import picker inside AuthNo. -->
            <intent-filter android:label="Add to AuthNo">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- .authbook -->
            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\.authbook" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\.authbook" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\.authbook" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\.authbook" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\..*\\.authbook" />
            </intent-filter>

            <intent-filter android:label="Open with AuthNo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\.authbook" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\.authbook" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\.authbook" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\.authbook" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\..*\\.authbook" />
            </intent-filter>

            <!-- .extbk -->
            <intent-filter android:label="Install AuthNo Extension">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-extbk" />
            </intent-filter>

            <intent-filter android:label="Install AuthNo Extension">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\.extbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\.extbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\.extbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\.extbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\..*\\.extbk" />
            </intent-filter>

            <intent-filter android:label="Install AuthNo Extension">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\.extbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\.extbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\.extbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\.extbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\..*\\.extbk" />
            </intent-filter>

            <!-- .thmbk (downloadable themes) -->
            <intent-filter android:label="Install AuthNo Theme">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-thmbk" />
            </intent-filter>

            <intent-filter android:label="Install AuthNo Theme">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\.thmbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\.thmbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\.thmbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\.thmbk" />
                <data android:scheme="content" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\..*\\.thmbk" />
            </intent-filter>

            <intent-filter android:label="Install AuthNo Theme">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\.thmbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\.thmbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\.thmbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\.thmbk" />
                <data android:scheme="file" android:mimeType="*/*"
                      android:pathPattern=".*\\..*\\..*\\..*\\..*\\.thmbk" />
            </intent-filter>

        </activity>

        <!-- ── Launcher icon aliases ──
             Exactly one is enabled at a time; AppIconPlugin flips them with
             PackageManager.setComponentEnabledSetting(..., DONT_KILL_APP).
             Component enabled state persists across reboots and updates, so
             the user's pick sticks. Only IconDefault ships enabled. -->
        <activity-alias
            android:name=".IconDefault"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconLight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_light"
            android:roundIcon="@mipmap/ic_launcher_light"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconRetro"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_retro"
            android:roundIcon="@mipmap/ic_launcher_retro"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconGold"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_gold"
            android:roundIcon="@mipmap/ic_launcher_gold"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- ── OAuth redirect handler (FIXED) ── -->
        <activity
            android:name=".OAuthFinishActivity"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoDisplay"
            android:launchMode="singleTask"
            android:exported="true">

            <!-- Google Drive -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.aurorastudios.authno"
                      android:host="oauth2"
                      android:pathPrefix="/gdrive" />
            </intent-filter>

            <!-- Dropbox -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.aurorastudios.authno"
                      android:host="oauth2"
                      android:pathPrefix="/dropbox" />
            </intent-filter>

            <!-- OneDrive -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.aurorastudios.authno"
                      android:host="oauth2"
                      android:pathPrefix="/onedrive" />
            </intent-filter>

        </activity>

        <!-- ── Widget provider ── -->
        <receiver
            android:name=".StreakWidgetProvider"
            android:label="@string/widget_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/streak_widget_info" />
        </receiver>

        <!-- ── Widget config ── -->
        <activity
            android:name=".StreakWidgetConfigActivity"
            android:label="@string/widget_config_label"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- ── File provider ── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        android:minSdkVersion="30" />

    <!-- Package visibility -->
    <queries>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
    </queries>

</manifest>
